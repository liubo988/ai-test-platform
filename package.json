{
  "name": "auto-test-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node server.mjs",
    "build": "tsc -p tsconfig.json",
    "build:web": "next build --webpack",
    "start:web": "NODE_ENV=production node server.mjs",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "test:smoke": "npm run test:unit && playwright test --grep @smoke",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:changed": "vitest related --run",
    "edge:generate": "node --env-file-if-exists=.env scripts/generate-tests.mjs",
    "edge:report": "node scripts/edge-report.mjs",
    "qa": "node scripts/qa.mjs",
    "test:api:product": "node scripts/api-product-regression.mjs",
    "db:init": "node --env-file-if-exists=.env scripts/init-e2e-db.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.15.21",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "mysql2": "^3.19.0",
    "next": "^16.1.6",
    "openai": "^6.25.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "ws": "^8.19.0"
  }
}
